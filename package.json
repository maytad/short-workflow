{
  "name": "short-workflow",
  "private": true,
  "packageManager": "bun@1.2.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@short-workflow/web",
    "dev:api": "turbo run dev --filter=@short-workflow/api",
    "dev:worker": "turbo run dev --filter=@short-workflow/worker",
    "dev:render": "turbo run dev --filter=@short-workflow/render",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "quality": "bun run format:check && bun run lint && bun run check && bun run typecheck",
    "check": "turbo run check",
    "typecheck": "turbo run typecheck",
    "db:generate": "bun run --cwd packages/db generate",
    "db:check": "bun run --cwd packages/db check",
    "db:migrate:up": "bun run --cwd packages/db migrate:up",
    "db:migrate:down": "bun run --cwd packages/db migrate:down",
    "db:studio": "bun run --cwd packages/db studio",
    "render:project": "bun run --cwd apps/render render:project"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
