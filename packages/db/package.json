{
  "name": "@short-workflow/db",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "generate": "bun --env-file=../../.env drizzle-kit generate",
    "check": "bun scripts/check.ts",
    "migrate:up": "bun --env-file=../../.env scripts/migrate.ts up",
    "migrate:down": "bun --env-file=../../.env scripts/migrate.ts down",
    "studio": "bun --env-file=../../.env drizzle-kit studio",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@short-workflow/shared": "workspace:*",
    "drizzle-orm": "latest",
    "postgres": "latest"
  },
  "devDependencies": {
    "drizzle-kit": "latest",
    "typescript": "latest"
  }
}
